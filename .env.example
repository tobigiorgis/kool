# ─── Base de datos (Neon PostgreSQL) ───────────────────────────────────────
DATABASE_URL="postgresql://..."
DIRECT_URL="postgresql://..."

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Analytics (Tinybird) ────────────────────────────────────────────────────
TINYBIRD_API_KEY=p.eyJ...
TINYBIRD_BASE_URL=https://api.tinybird.co

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM="Kool <hola@kool.link>"

# ─── Tiendanube OAuth ────────────────────────────────────────────────────────
TIENDANUBE_CLIENT_ID=...
TIENDANUBE_CLIENT_SECRET=...
# Debe coincidir EXACTO con la Redirect URI registrada en la app de Tiendanube.
TIENDANUBE_REDIRECT_URI=https://app.joinkool.co/api/auth/tiendanube/callback

# ─── App ─────────────────────────────────────────────────────────────────────
# Dominio canónico de la app (dashboard marca + portal creator).
NEXT_PUBLIC_APP_URL=https://app.joinkool.co
# Dominio corto de los links de afiliado (lo resuelve src/middleware.ts y lo
# muestra la UI vía buildShortUrl). Default "kool.link" si no se setea.
NEXT_PUBLIC_SHORT_DOMAIN=refer.joinkool.co
WEBHOOK_SECRET=...

# ─── Dominios (routing multi-host) ───────────────────────────────────────────
# Seteá estos cuando joinkool.co esté propagado y agregado en Vercel.
# Si quedan VACÍOS, la app funciona en un solo dominio como hasta ahora (sin
# redirects). Ver DOMAINS.md para el checklist de cutover.
# NEXT_PUBLIC_ROOT_DOMAIN: dejar SIN setear si Vercel ya redirige apex → www.
NEXT_PUBLIC_APP_DOMAIN=app.joinkool.co         # dominio canónico (dashboard)
NEXT_PUBLIC_CREATOR_DOMAIN=creator.joinkool.co # portal de creators (nativo, URL limpia)
# Dev: para probar el split de hosts en local usá lvh.me (→127.0.0.1, soporta
# subdominios sin /etc/hosts): NEXT_PUBLIC_APP_DOMAIN=app.lvh.me,
# NEXT_PUBLIC_CREATOR_DOMAIN=creator.lvh.me → abrí http://creator.lvh.me:3000

# ─── Encriptación (para access tokens de Tiendanube) ─────────────────────────
ENCRYPTION_KEY=... # 32 bytes hex
